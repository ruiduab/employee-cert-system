# 联想员工认证系统 - 环境配置

# 服务器配置
PORT=8000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=lenovo_cert
DB_PORT=3306

# CORS 配置
CORS_ORIGIN=http://localhost:3000,http://101.132.158.166:8082,http://101.132.158.166:8083

# 日志配置
LOG_LEVEL=info

# JWT 配置（如果需要）
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 短信服务配置（示例：腾讯云 SMS）
SMS_REGION=ap-beijing
SMS_SDK_APP_ID=your_sdk_app_id
SMS_SIGN_NAME=联想

# 邮件服务配置（示例：SendGrid）
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@lenovo.com
